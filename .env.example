# =============================================================================
# Plan de Trabajo — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# =============================================================================

# ---- Django Core -----------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ---- PostgreSQL ------------------------------------------------------------
DB_NAME=plantrabajo
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# ---- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---- CORS / CSRF -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8000,https://your-domain.com

# ---- Throttle Rates --------------------------------------------------------
THROTTLE_RATE_ANON=60/hour
THROTTLE_RATE_USER=300/hour
THROTTLE_RATE_WRITE=60/hour
THROTTLE_RATE_AUTH=10/hour
THROTTLE_RATE_REPORT=30/hour

# ---- Email (SMTP) ----------------------------------------------------------
# Leave blank to use console backend (dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@plantrabajo.cu

# ---- LDAP ------------------------------------------------------------------
LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin

# ---- Sentry ----------------------------------------------------------------
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
