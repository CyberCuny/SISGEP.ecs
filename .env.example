# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (PostgreSQL)
DB_NAME=plantrabajo
DB_USER=postgres
DB_PASSWORD=a
DB_HOST=localhost
DB_PORT=5432

# Redis (required for channels, cache, sessions in production)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000,https://yourdomain.com

# LDAP
LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=admin

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@plantrabajo.cu

# Sentry (error tracking)
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.2

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/plantrabajo

# Media
MEDIA_ROOT=/app/media

# Port for docker-compose
PORT=80

# Maintenance mode (crear archivo en esta ruta para activar 503)
MAINTENANCE_FILE=/tmp/maintenance.flag

# Cron: respaldo automático diario (ejemplo crontab -e):
# 0 3 * * * cd /app && python manage.py daily_backup --keep=7 >> /var/log/plantrabajo/backup.log 2>&1
